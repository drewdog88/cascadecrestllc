# Copy to .env.local for local development (never commit .env.local)

# Admin sign-in at /admin/login (min 16 characters)
ADMIN_SECRET=

# Applicant RentSpree invite (used on /apply)
NEXT_PUBLIC_SCREENING_INVITE_URL=https://apply.link/K6AP5pA
SCREENING_INVITE_URL=https://apply.link/K6AP5pA

# Optional fee text on /apply
# SCREENING_FEE_DISCLOSURE=$39.99–$49.99 (applicant pays screening partner)

# Optional — production site URL for metadata
# NEXT_PUBLIC_SITE_URL=https://www.cascadecrestllc.com

# Optional — GA4 (production only on Vercel)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
